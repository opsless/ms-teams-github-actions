{
  "name": "@opsless/ms-teams-github-actions",
  "version": "2.2.0",
  "private": true,
  "description": "MS Teams Github Actions integration",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "package": "ncc build src/main.ts -m -o dist/main",
    "test": "jest",
    "all": "npm run build && npm run format:write && npm run lint && npm run package && npm test"
  },
  "author": "opsless.io team",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^6.0.0",
    "adaptive-expressions": "^4.20.1",
    "adaptivecards": "^3.0.1",
    "adaptivecards-templating": "^2.3.1",
    "cockatiel": "^3.1.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vercel/ncc": "^0.38.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
